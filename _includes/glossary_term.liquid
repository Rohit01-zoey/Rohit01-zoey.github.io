{% assign glossary_key = include.key | default: include.term | strip | downcase %}
{% assign glossary_entry = nil %}

{% for item in site.data.glossary %}
  {% unless glossary_entry %}
    {% assign item_slug = item.slug | downcase %}
    {% assign item_term = item.term | downcase %}
    {% if item_slug == glossary_key or item_term == glossary_key %}
      {% assign glossary_entry = item %}
    {% else %}
      {% for alias in item.aliases %}
        {% assign alias_key = alias | downcase %}
        {% if alias_key == glossary_key %}
          {% assign glossary_entry = item %}
        {% endif %}
      {% endfor %}
    {% endif %}
  {% endunless %}
{% endfor %}

{% if glossary_entry %}
  {% if include.display %}
    {% assign glossary_display = include.display %}
  {% elsif glossary_key == glossary_entry.slug %}
    {% assign glossary_display = glossary_entry.term %}
  {% else %}
    {% assign glossary_display = include.key | default: include.term %}
  {% endif %}

  {% assign glossary_page_url = '/glossary/' | relative_url %}
  {% capture glossary_popover_body %}
    {{ glossary_entry.definition | markdownify | strip_newlines }}
    <p class="glossary-popover-footer mb-0">
      <a class="glossary-popover-link" href="{{ glossary_page_url }}#{{ glossary_entry.slug }}">View in glossary &rarr;</a>
    </p>
  {% endcapture %}

  <span
    class="glossary-term"
    tabindex="0"
    role="button"
    data-toggle="popover"
    data-trigger="hover focus"
    data-placement="top"
    data-html="true"
    title="{{ glossary_entry.term | escape }}"
    data-content="{{ glossary_popover_body | strip_newlines | escape }}"
  >{{ glossary_display }}</span>
{% else %}
  <span class="glossary-term glossary-term-missing" title="Glossary entry not found">{{ include.key | default: include.term }}</span>
{% endif %}
